import json
import os

LIBRARY_FILE = "library.json"


def save_books():
    try:
        with open(LIBRARY_FILE, 'w', encoding='utf-8') as file:
            json.dump(Books, file, ensure_ascii=False, indent=4)
    except:
        print("Ошибка при сохранении файла")


def load_books():
    global Books
    if os.path.exists(LIBRARY_FILE):
        try:
            with open(LIBRARY_FILE, 'r', encoding='utf-8') as file:
                Books = json.load(file)
            print(f"Загружено {len(Books)} книг из файла")
        except:
            print("Ошибка при загрузке файла")
            Books = []
    else:
        Books = []


def display_book(book, index=None):
    prefix = f"{index}. " if index else ""
    print(f"{prefix}{book['название']} — {book['автор']} ({book['год']})")
    print(f"   Жанр: {book['жанр']}")
    print(
        f"   Статус: {'✓ Прочитана' if book['прочитано'] else '○ Не прочитана'} | {'★ В избранном' if book['избранная'] else '☆ Не в избранном'}")
    print(f"   Описание: {book['описание'][:100]}..." if len(
        book['описание']) > 100 else f"   Описание: {book['описание']}")
    print("-" * 50)


def sort_books(books, key, reverse=False):

    if key == "год":
        return sorted(books, key=lambda x: int(x[key]), reverse=reverse)
    return sorted(books, key=lambda x: x[key].lower(), reverse=reverse)


